# Node.js rollback backend
PORT=5000

# FastAPI migration backend
APP_ENV=development
APP_NAME=FLIC FastAPI Backend
APP_VERSION=fastapi-v1
FASTAPI_PORT=8000

# Microsoft SQL Server
DB_SERVER=localhost
DB_PORT=1433
DB_DATABASE=dbFLIC_dev
DB_NAME=dbFLIC_dev
DB_USER=sa
DB_PASSWORD=your_password
DB_DRIVER=ODBC Driver 17 for SQL Server
DB_ENCRYPT=false
DB_TRUST_SERVER_CERTIFICATE=true
DB_TIMEOUT_SECONDS=5

# CORS
CORS_ORIGIN=*
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://127.0.0.1:5173

# Python ml-service
ML_SERVICE_URL=http://localhost:8001
ML_TIMEOUT_SECONDS=15

# Node sentiment bridge compatibility
ML_TIMEOUT_MS=5000
ML_TIMEOUT_FIRST_MS=15000
ML_MIN_TEXT_LENGTH=2
ML_MODEL_VERSION=phobert-onnx-v1
SENTIMENT_MODE=ensemble
ENSEMBLE_MODEL_VERSION=ensemble-phobert-rule-v1
REQUIRE_VISOBERT=false

# Reprocess guard. Keep writes disabled unless explicitly approved.
ENSEMBLE_DRY_RUN=true
ENSEMBLE_WRITE_DB=false
ML_WARMUP_ENABLED=true
ML_WARMUP_TEXT=xin chao

# SMTP Configuration
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_SENDER=your_email@gmail.com
