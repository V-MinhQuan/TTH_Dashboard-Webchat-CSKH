# Đường dẫn kết nối API Backend (dành cho Frontend React/Vite)
# Frontend chạy ở port 5173, gọi về Backend FastAPI ở port 5000
VITE_API_BASE_URL=http://127.0.0.1:5000

# Cổng chạy backend server
PORT=5000

# Thông tin kết nối Microsoft SQL Server
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_SERVER=your_db_server_ip_or_domain
DB_PORT=1433
DB_DATABASE=Dashboard_ChatBot

# Mã hóa kết nối (đặt false nếu database không cấu hình SSL/TLS)
DB_ENCRYPT=false

# Cho phép tự ký chứng chỉ SSL/TLS
DB_TRUST_SERVER_CERTIFICATE=true

# CORS Origins — danh sách domain frontend được phép gọi API (ngăn cách bởi dấu phẩy)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:3000

# ML Service URL (chạy ở port 8001)
ML_SERVICE_URL=http://localhost:8001

# ── Phân quyền người dùng ───────────────────────────────────────────────────
# Danh sách username được cấp role 'manager' (phân quyền trong code)
MANAGER_USERNAMES=test,thuynt
