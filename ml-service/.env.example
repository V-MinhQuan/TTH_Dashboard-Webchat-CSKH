# ─── ml-service — Biến môi trường ────────────────────────────────────────────
# Sao chép file này thành .env và điền giá trị phù hợp.
# Không commit file .env lên Git.

# ─── CORS ─────────────────────────────────────────────────────────────────────

# Danh sách origin được phép gọi ml-service, phân cách bằng dấu phẩy.
# Chỉ liệt kê origin cần thiết (FastAPI backend).
# Không dùng * vì ml-service chỉ nhận request nội bộ từ backend.
ML_ALLOWED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

# ─── Persistent Metrics ────────────────────────────────────────────────────────

# Bật/tắt lưu metrics ra file JSON.
# true  → Metrics tích lũy qua các lần restart, đọc từ file lúc khởi động.
# false → Metrics chỉ in-memory, mất khi restart.
METRICS_PERSIST_ENABLED=true

# Đường dẫn file JSON lưu metrics.
# Thư mục data/ được tạo tự động nếu chưa tồn tại.
# File này được thêm vào .gitignore — không commit lên Git.
METRICS_FILE_PATH=./data/metrics.json

# Số requests giữa mỗi lần ghi file metrics.
# Tăng nếu I/O disk là vấn đề, giảm nếu cần cập nhật thường xuyên hơn.
# Tối thiểu: 1 (ghi sau mỗi request — không khuyến nghị trong production)
METRICS_FLUSH_INTERVAL=10

# ─── Sentiment mode / Ensemble ───────────────────────────────────────────────
# phobert  → /predict trả kết quả PhoBERT như hiện tại
# visobert → /predict trả kết quả ViSoBERT adapter nếu đã bật model
# ensemble → /predict trả final label từ ensemble; /predict-ensemble luôn trả audit đầy đủ
SENTIMENT_MODE=ensemble

# Version ghi vào response ensemble và analyzerVersion phía backend/reprocess.
MODEL_VERSION=ensemble-phobert-visobert-v1

# ViSoBERT adapter mặc định tắt. Bật experimental chỉ khi đã xác nhận checkpoint.
ENABLE_VISOBERT=false
VISOBERT_EXPERIMENTAL_PYTORCH=false
VISOBERT_MODEL_NAME=

# true -> backend dry-run/reprocess dung lai neu ViSoBERT chua san sang.
# false -> cho phep fallback PhoBERT + rule va tra actualAnalyzerVersion=ensemble-phobert-rule-v1.
REQUIRE_VISOBERT=false

# Guard để ghi DB nằm ở backend scripts, không phải ml-service.
ENSEMBLE_DRY_RUN=true
ENSEMBLE_WRITE_DB=false
